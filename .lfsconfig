[lfs]
	# Fetch LFS objects from comma public store (same as upstream).
	url = https://gitlab.com/commaai/openpilot-lfs.git/info/lfs
	# Pushes must go to your fork on GitHub — you cannot push LFS to comma’s GitLab without their credentials.
	pushurl = https://github.com/ugtthis/openpilot.git/info/lfs
	locksverify = false
